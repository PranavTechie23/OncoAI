# Backend example environment variables
# Copy to backend/.env and fill values for local development.

# Database (Postgres) connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Flask secret key (use a secure random value in production)
SECRET_KEY=your-very-secret-key

# OpenAI (server-side) API key
OPENAI_API_KEY=sk-...

# Optional: enforce auth hours during testing
ENFORCE_AUTH_HOURS=0

# Optional: set to production base URL for client
# VITE_API_URL=https://your-frontend-domain

# Comma-separated front-end origins to allow for CORS in production
# Example: FRONTEND_ORIGINS=https://app.yourdomain.com,https://staging.yourdomain.com
FRONTEND_ORIGINS=
